# Supabase（ローカル用。このファイルをコピーして .env.local を作成）
# cp .env.local.example .env.local

# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# service_role / secret は CLI・サーバー専用。NEXT_PUBLIC_ を付けないこと。ブラウザに出さないこと。
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ログイン表示用（犬なでなで）で使用する Auth ユーザーの実メール（サーバー専用・NEXT_PUBLIC_禁止）
AUTH_LOGIN_EMAIL=your_auth_user_email@example.com
